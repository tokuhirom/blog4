# 1Password CLI (op run) で Terraform に認証情報を注入するためのテンプレ。
#
# !!! ここには op:// 参照だけを書く。解決後の実値は絶対に書かない !!!
# 値は 1Password (blog4 vault) が正本。このファイルは参照だけなので commit してよい。
#
# 使い方:
#   op signin
#   op run --env-file=.env -- terraform plan
#
# 参照先の 1Password アイテム (blog4 vault に以下の item/field を作る):
#   blog4-sakura-api      : token, secret                      (さくらのクラウド API キー / provider 用)
#   blog4-object-storage  : access-key-id, secret-access-key   (Object Storage S3 キー / backend 用)
#   blog4-tidb            : root-password                       (TiDB CR root パスワード)

# さくらのクラウド API (provider 用)
SAKURACLOUD_ACCESS_TOKEN="op://blog4/blog4-sakura-api/token"
SAKURACLOUD_ACCESS_TOKEN_SECRET="op://blog4/blog4-sakura-api/secret"

# オブジェクトストレージの S3 アクセスキー (backend 用)
AWS_ACCESS_KEY_ID="op://blog4/blog4-object-storage/access-key-id"
AWS_SECRET_ACCESS_KEY="op://blog4/blog4-object-storage/secret-access-key"

# TiDB CR root パスワード (write-only var)
TF_VAR_tidb_password="op://blog4/blog4-tidb/root-password"
TF_VAR_tidb_password_version=1
TF_VAR_tidb_database_name=blog5

